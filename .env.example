ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis

# Redis
REDIS_URL=redis://redis:6379/0

# Meilisearch
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=aegis-backend

# AI Providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_ASSETS=aegis-assets
MINIO_SECURE=false

# AI rate limits
AI_CACHE_TTL_SECONDS=86400
AI_RATE_LIMIT_TRAINEE=60
AI_RATE_LIMIT_INSTRUCTOR=200
AI_GLOBAL_RATE_LIMIT=2000
AI_PROVIDER_TIMEOUT_SECONDS=15

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
python.terminal.useEnvFile